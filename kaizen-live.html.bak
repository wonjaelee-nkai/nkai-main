};

var DIET_DB = {
  木:{icon:'🥗',good:'녹색채소 · 보리 · 부추 · 식초 · 레몬',bad:'기름진 음식 · 과음 · 튀김류',rec:'나물비빔밥 · 샐러드 · 녹즙 · 간해독주스'},
