<script>
// ── CONFIG ──────────────────────────────────────────
var TOSS_CLIENT_KEY = 'test_ck_oEjb0gm23P4vBwp96WJk3pGwBJn5';
var PLANS = {
  full:      {name:'전체 분석',       price:3900,  type:'one-time'},
  ai:        {name:'전체+AI 상담',    price:9900,  type:'one-time'},
  unlimited: {name:'무제한 월정액',   price:19900, type:'subscription'}
};
var state = {birth:null,birthStr:null,gender:'F',hourIdx:null,vCore:null,plan:'full',userPlan:null};

// ── SAJU ENGINE (diff+11 보정) ──────────────────────
var GANS  = ['甲','乙','丙','丁','戊','己','庚','辛','壬','癸'];
var ZHIS  = ['子','丑','寅','卯','辰','巳','午','未','申','酉','戌','亥'];
var GAN_EL = {甲:'木',乙:'木',丙:'火',丁:'火',戊:'土',己:'土',庚:'金',辛:'金',壬:'水',癸:'水'};
var ZHI_EL = {子:'水',丑:'土',寅:'木',卯:'木',辰:'土',巳:'火',午:'火',未:'土',申:'金',酉:'金',戌:'土',亥:'水'};
var EL_KO    = {木:'목',火:'화',土:'토',金:'금',水:'수'};
var EL_COLOR = {木:'var(--wood)',火:'var(--fire)',土:'var(--earth)',金:'var(--metal)',水:'var(--water)'};
var EL_EMOJI = {木:'🌿',火:'🔥',土:'🏔',金:'⚔️',水:'💧'};
var EL_BG    = {木:'rgba(34,197,94,0.12)',火:'rgba(239,68,68,0.12)',土:'rgba(245,158,11,0.12)',金:'rgba(148,163,184,0.12)',水:'rgba(59,130,246,0.12)'};

var LICHUN = {
  1920:[2,5],1921:[2,4],1930:[2,4],1940:[2,5],1950:[2,4],1960:[2,5],1970:[2,4],1980:[2,5],
  1981:[2,4],1982:[2,4],1983:[2,4],1984:[2,4],1985:[2,4],1986:[2,4],1987:[2,4],1988:[2,4],
  1989:[2,4],1990:[2,4],1991:[2,4],1992:[2,4],1993:[2,4],1994:[2,4],1995:[2,4],1996:[2,4],
  1997:[2,4],1998:[2,4],1999:[2,4],2000:[2,4],2001:[2,4],2002:[2,4],2003:[2,4],2004:[2,4],
  2005:[2,4],2006:[2,4],2007:[2,4],2008:[2,4],2009:[2,4],2010:[2,4],2011:[2,4],2012:[2,4],
  2013:[2,4],2014:[2,4],2015:[2,4],2016:[2,4],2017:[2,3],2018:[2,4],2019:[2,4],2020:[2,4],
  2021:[2,3],2022:[2,4],2023:[2,4],2024:[2,4],2025:[2,3],2026:[2,4],2027:[2,4],2028:[2,4]
};
var BRANCH_RATIO = {
  子:[0,0,0,0,1],丑:[0,0,.6,.2,.2],寅:[.6,.3,.1,0,0],卯:[1,0,0,0,0],
  辰:[.2,0,.6,0,.2],巳:[0,.6,.1,.3,0],午:[0,.7,.3,0,0],未:[.2,.2,.6,0,0],
  申:[0,0,.1,.6,.3],酉:[0,0,0,1,0],戌:[0,.1,.7,.2,0],亥:[.3,0,0,0,.7]
};

function getSajuYear(y,m,d){var lc=LICHUN[y]||[2,4];return(m<lc[0]||(m===lc[0]&&d<lc[1]))?y-1:y;}
function getYearGan(y){return GANS[((y-4)%10+10)%10];}
function getYearZhi(y){return ZHIS[((y-4)%12+12)%12];}
function getMonthGan(yIdx,m){return GANS[((yIdx%5)*2+(m<2?m+12:m))%10];}
function getMonthZhi(m){return['丑','寅','卯','辰','巳','午','未','申','酉','戌','亥','子'][m-1];}
function getDayGan(y,m,d){var b=new Date(1900,0,1),t=new Date(y,m-1,d),diff=Math.floor((t-b)/86400000);return GANS[(diff+11)%10];}
function getDayZhi(y,m,d){var b=new Date(1900,0,1),t=new Date(y,m-1,d),diff=Math.floor((t-b)/86400000);return ZHIS[(diff+11)%12];}
function getHourGan(dIdx,h){return GANS[((dIdx%5)*2+h)%10];}
function getHourZhi(h){return ZHIS[h%12];}

function computeSaju(bs,hi_raw){
  var y=parseInt(bs.slice(0,4)),m=parseInt(bs.slice(4,6)),d=parseInt(bs.slice(6,8));
  var sy=getSajuYear(y,m,d);
  var yGan=getYearGan(sy),yZhi=getYearZhi(sy),yIdx=GANS.indexOf(yGan);
  var mGan=getMonthGan(yIdx,m),mZhi=getMonthZhi(m);
  var dGan=getDayGan(y,m,d),dZhi=getDayZhi(y,m,d);
  var hGan=null,hZhi=null;
  var hi=(hi_raw!==null&&hi_raw!==''&&!isNaN(parseInt(hi_raw)))?parseInt(hi_raw):-1;
  if(hi>=0){var dIdx=GANS.indexOf(dGan);hGan=getHourGan(dIdx,hi);hZhi=getHourZhi(hi);}
  var oh={木:0,火:0,土:0,金:0,水:0};
  var stems=[yGan,mGan,dGan];
  var branches=[{z:yZhi,w:1.2},{z:mZhi,w:2.5},{z:dZhi,w:1.2}];
  if(hGan){stems.push(hGan);branches.push({z:hZhi,w:1.2});}
  stems.forEach(function(g){oh[GAN_EL[g]]+=1.0;});
  branches.forEach(function(it){
    var r=BRANCH_RATIO[it.z]||[.2,.2,.2,.2,.2];
    ['木','火','土','金','水'].forEach(function(e,i){oh[e]+=r[i]*it.w;});
  });
  var el=GAN_EL[dGan];
  var gen={木:'火',火:'土',土:'金',金:'水',水:'木'};
  var ctl={木:'土',土:'水',水:'火',火:'金',金:'木'};
  var gby={火:'木',土:'火',金:'土',水:'金',木:'水'};
  var cby={土:'木',水:'土',火:'水',金:'火',木:'金'};
  var Ein=oh[el]+(oh[gby[el]]||0);
  var Eout=(oh[gen[el]]||0)+(oh[ctl[el]]||0)+(oh[cby[el]]||0);
  var si=(Ein-Eout)/(Ein+Eout+1e-9);
  return{saju:{yGan,yZhi,mGan,mZhi,dGan,dZhi,hGan,hZhi},dayEl:el,oh,si,
    wealthEl:ctl[el],exprEl:gen[el],precision:hi>=0?94:82};
}

// ── DATA ────────────────────────────────────────────
var P_DB = {
  木:{emoji:'🌿',name:'木(목)',trait:'진취적 · 도전적',
    desc:'성장과 창조의 에너지. 리더십과 추진력이 강하며 새로운 시작을 즐깁니다. 기획력과 창의성이 뛰어나지만 인내심이 부족할 수 있습니다.',
    organs:'간 · 눈 · 근육 · 인대',
    stress:'스트레스 받으면 두피 경직, 어깨 뭉침, 눈 피로 급증'},
  火:{emoji:'🔥',name:'火(화)',trait:'열정적 · 표현력',
    desc:'열정과 표현의 에너지. 카리스마가 있고 사람들을 끌어당기는 매력이 있습니다. 커뮤니케이션 능력이 탁월하지만 감정 기복에 주의가 필요합니다.',
    organs:'심장 · 혈관 · 안색 · 소장',
    stress:'흥분하면 얼굴 홍조, 열감, 불면, 심계항진'},
  土:{emoji:'🏔',name:'土(토)',trait:'안정적 · 포용력',
    desc:'안정과 신뢰의 에너지. 실용적이고 믿음직하며 사람들의 중심이 됩니다. 조율 능력이 탁월하지만 변화를 싫어하는 면이 있습니다.',
    organs:'위장 · 소화기 · 비장',
    stress:'스트레스 받으면 피부 칙칙해지고 부종 발생, 소화 불량'},
  金:{emoji:'⚔️',name:'金(금)',trait:'섬세 · 완벽주의',
    desc:'정밀과 결단의 에너지. 분석적이고 원칙을 중시하며 높은 기준을 추구합니다. 집중력이 탁월하지만 타협이 어려운 면이 있습니다.',
    organs:'폐 · 피부 · 대장 · 코',
    stress:'환절기 피부 건조·트러블, 호흡기 약함, 변비'},
  水:{emoji:'💧',name:'水(수)',trait:'지혜 · 인내',
    desc:'지혜와 깊이의 에너지. 직관력이 뛰어나고 유연하게 상황에 적응합니다. 통찰력이 탁월하지만 우유부단한 면이 있습니다.',
    organs:'신장 · 뼈 · 귀 · 방광',
    stress:'피로하면 다크서클, 탈모, 허리 통증, 이명'}
};

var SKIN_DB = {
  木:{free:'이번 달 두피·어깨 경직과 피부 트러블 주의 시기예요.',
    skin:'약산성 클렌저로 피부 장벽 강화. 녹차·티트리 앰플로 진정 케어. 스트레스 관리가 피부 케어의 핵심. SPF 50+ 자외선 차단 필수.',
    hair:'두피 스켈링 월 1회 권장. 샴푸 전 두피 마사지 3분으로 혈행 개선. 약산성 샴푸로 두피 pH 유지. 드라이 후 두피 에센스 사용.',
    caution:'새 제품 도입 전 팔 안쪽 48시간 패치 테스트 필수. 이번 달은 민감도가 올라가는 시기이니 강한 필링·시술은 자제.'},
  火:{free:'이번 달 열감·홍조가 심해질 수 있어요. 쿨링 케어가 핵심입니다.',
    skin:'쿨링 미스트·알로에 젤로 즉각 진정. 논코메도제닉 제품 사용. 수분 세럼 아침저녁 2회로 열 진정.',
    hair:'쿨링 두피 토닉으로 두피 열감 완화. 뜨거운 물 사용 금지, 미온수로 헹굼. 쿨링 트리트먼트 주 2회.',
    caution:'카페인, 매운 음식, 음주 후 피부 트러블 주의. 강한 레이저 시술은 이번 달 자제.'},
  土:{free:'이번 달 칙칙함과 부종이 심해질 수 있어요. 각질·비타민C 케어 시작하세요.',
    skin:'각질 제거 주 1~2회 저자극 스크럽. 비타민C 세럼으로 칙칙함 개선. 콜라겐 앰플로 탄력 보강.',
    hair:'볼륨업 샴푸 사용. 두피 스케일링 주 1회. 단백질 트리트먼트로 모발 강도 개선.',
    caution:'밀가루, 찬 음식 과다 섭취 주의. 림프 마사지로 부종 관리.'},
  金:{free:'이번 달 피부 건조함이 극심해질 수 있어요. 세라마이드 집중 보습이 핵심.',
    skin:'세라마이드 크림으로 피부 장벽 강화. 히알루론산 토너 2~3회 레이어링. 배꿀팩 주 2회로 수분 충전.',
