// ── ANALYZE ─────────────────────────────────────────
function doAnalyze(){
  var d=document.getElementById('birth-date').value;
  if(!d){showToast('생년월일을 입력해주세요');return;}
  var p=d.split('-');
  state.birthStr=p[0]+p[1]+p[2];
  state.birth=new Date(d);
  state.gender=document.getElementById('birth-gender').value;
  var hv=document.getElementById('birth-hour').value;
  state.hourIdx=hv===''?null:hv;
  state.vCore=computeSaju(state.birthStr,state.hourIdx);

  renderS1(); renderS2(); renderS3(); renderS4(); renderS5(); renderS6(); renderPricing();

  var sf=document.getElementById('story-flow');
  sf.classList.add('show');
  setTimeout(function(){sf.scrollIntoView({behavior:'smooth'});},100);
  showToast('분석 완료! '+EL_EMOJI[state.vCore.dayEl]+' '+state.vCore.dayEl+'('+EL_KO[state.vCore.dayEl]+') 일간');
}

// S1 — DNA
function renderS1(){
  var vc=state.vCore,sj=vc.saju;
  var pillars=[{l:'年柱',g:sj.yGan,z:sj.yZhi},{l:'月柱',g:sj.mGan,z:sj.mZhi},
               {l:'日柱',g:sj.dGan,z:sj.dZhi},{l:'時柱',g:sj.hGan||'?',z:sj.hZhi||'?'}];
  document.getElementById('s1-grid').innerHTML=pillars.map(function(p){
    var ge=GAN_EL[p.g]||'土',ze=ZHI_EL[p.z]||'土';
    return '<div class="saju-pillar"><span class="pl">'+p.l+'</span>'
      +'<div class="pg" style="color:'+EL_COLOR[ge]+'">'+p.g+'</div>'
      +'<div class="pz" style="color:'+EL_COLOR[ze]+'">'+p.z+'</div></div>';
  }).join('');

  var oh=vc.oh,els=['木','火','土','金','水'];
  var mx=Math.max.apply(null,els.map(function(e){return oh[e];}));
  document.getElementById('s1-bars').innerHTML=els.map(function(e){
    var pct=mx?Math.round(oh[e]/mx*100):0;
    return '<div class="oh-row">'
      +'<span class="oh-lbl" style="color:'+EL_COLOR[e]+'">'+e+'</span>'
      +'<div class="oh-bg"><div class="oh-fill" id="ohf-'+e+'" style="background:'+EL_COLOR[e]+'"></div></div>'
      +'<span class="oh-val">'+oh[e].toFixed(1)+'</span></div>';
  }).join('');
  // animate bars
  setTimeout(function(){
    els.forEach(function(e){
      var bar=document.getElementById('ohf-'+e);
      if(bar) bar.style.width=Math.round(oh[e]/mx*100)+'%';
    });
  },80);

  var el=vc.dayEl,Pd=P_DB[el];
  document.getElementById('s1-banner').innerHTML=
    '<div style="font-size:14px;font-weight:800;color:'+EL_COLOR[el]+'">'+Pd.emoji+' 당신은 '+Pd.name+' 오행 — '+Pd.trait+'</div>'
    +'<div style="font-size:13px;color:var(--muted);margin-top:6px;line-height:1.6">'+Pd.desc.split('.')[0]+'.</div>'
    +'<div style="font-size:11px;color:var(--accent2);margin-top:8px">정밀도 '+vc.precision+'% · '+(state.hourIdx?'시간 반영':'생년월일 기준')+'</div>';
}

// S2 — Personality
function renderS2(){
  var myEl=state.vCore.dayEl;
  document.getElementById('s2-body').innerHTML=['木','火','土','金','水'].map(function(e){
    var Pd=P_DB[e],isMe=e===myEl;
    return '<div class="el-block'+(isMe?' me':'')+'" style="background:'+EL_BG[e]+';border-color:'+(isMe?EL_COLOR[e]:'var(--border)')+';">'
      +'<div class="el-header"><span style="font-size:20px">'+Pd.emoji+'</span>'
      +'<span style="color:'+EL_COLOR[e]+'">'+Pd.name+'</span>'
      +'<span style="font-size:12px;color:var(--muted)">'+Pd.trait+'</span>'
      +(isMe?'<span class="me-badge">내 오행</span>':'')
      +'</div>'
      +'<div class="el-trait">'+Pd.desc+'</div>'
      +'<div class="organ-wrap">'
      +'<div class="organ-line"><i class="fa-solid fa-heart-pulse" style="color:'+EL_COLOR[e]+';margin-right:5px"></i>'+Pd.organs+'</div>'
      +'<div class="stress-line"><i class="fa-solid fa-triangle-exclamation" style="margin-right:5px"></i>'+Pd.stress+'</div>'
      +'</div></div>';
  }).join('');
}

// S3 — Skin month
function renderS3(){
  var el=state.vCore.dayEl,S=SKIN_DB[el];
  var mn=(new Date().getMonth()+1)+'월';
  document.getElementById('s3-free').innerHTML=
    '<div style="font-size:12px;color:var(--muted);margin-bottom:6px">'+EL_EMOJI[el]+' '+el+'('+EL_KO[el]+') 오행 · '+mn+' 피부 운세</div>'
    +'<div class="skin-free-title">'+S.free+'</div>'
    +'<div style="font-size:12px;color:var(--muted);margin-top:8px">상세 관리법은 프리미엄에서 확인하세요 ↓</div>';
  document.getElementById('s3-blur').innerHTML=
    '<span class="w-lbl">피부 관리 포인트</span>'
    +'<div class="el-block" style="background:'+EL_BG[el]+';margin-bottom:10px"><div style="font-size:13px;line-height:1.7">'+S.skin+'</div></div>'
    +'<span class="w-lbl">헤어 관리 포인트</span>'
    +'<div class="el-block" style="background:'+EL_BG[el]+';margin-bottom:10px"><div style="font-size:13px;line-height:1.7">'+S.hair+'</div></div>'
    +'<span class="w-lbl">주의사항</span>'
    +'<div class="el-block" style="background:'+EL_BG[el]+'"><div style="font-size:13px;line-height:1.7">'+S.caution+'</div></div>';
}

// S4 — Diet
function renderS4(){
  var myEl=state.vCore.dayEl;
  document.getElementById('s4-blur').innerHTML=['木','火','土','金','水'].map(function(e){
    var D=DIET_DB[e],isMe=e===myEl;
    return '<div class="item-block'+(isMe?' me':'')+'" style="border-color:'+(isMe?EL_COLOR[e]:'var(--border)')+';">'
      +'<div class="item-header"><span style="font-size:20px">'+D.icon+'</span>'
      +'<span style="color:'+EL_COLOR[e]+'">'+P_DB[e].emoji+' '+e+'('+EL_KO[e]+')</span>'
      +(isMe?'<span class="me-badge" style="background:'+EL_COLOR[e]+'">내 오행</span>':'')
      +'</div>'
      +'<div><span class="wtag wtag-g">추천 식품</span><div style="font-size:12px;color:var(--text);margin:4px 0 8px;line-height:1.6">'+D.good+'</div></div>'
      +'<div><span class="wtag wtag-b">피할 것</span><div style="font-size:12px;color:var(--muted);margin:4px 0 8px;line-height:1.6">'+D.bad+'</div></div>'
      +'<div><span class="wtag wtag-r">추천 레시피</span><div style="font-size:12px;color:var(--text);margin:4px 0 0;line-height:1.6">'+D.rec+'</div></div>'
      +'</div>';
  }).join('');
}

// S5 — Exercise
function renderS5(){
  var myEl=state.vCore.dayEl;
  document.getElementById('s5-blur').innerHTML=['木','火','土','金','水'].map(function(e){
    var EX=EXERCISE_DB[e],isMe=e===myEl;
    return '<div class="item-block'+(isMe?' me':'')+'" style="border-color:'+(isMe?EL_COLOR[e]:'var(--border)')+';">'
      +'<div class="item-header"><span style="font-size:20px">'+EX.icon+'</span>'
      +'<span style="color:'+EL_COLOR[e]+'">'+P_DB[e].emoji+' '+e+'('+EL_KO[e]+')</span>'
      +'<span style="font-size:11px;color:var(--muted)">'+EX.focus+'</span>'
      +(isMe?'<span class="me-badge" style="background:'+EL_COLOR[e]+'">내 오행</span>':'')
      +'</div>'
      +'<div style="font-weight:700;font-size:13px;margin-bottom:6px">'+EX.title+'</div>'
      +'<div style="font-size:12px;color:var(--muted);line-height:1.6">'+EX.desc+'</div>'
      +'</div>';
  }).join('');
}

// S6 — Beauty products
function renderS6(){
  var myEl=state.vCore.dayEl;
  var prods=BEAUTY_DB[myEl]||[];
  var cats=[],catMap={};
  prods.forEach(function(p){
    if(!catMap[p.cat]){cats.push(p.cat);catMap[p.cat]=[];}
    catMap[p.cat].push(p);
  });
  var html='<div style="background:'+EL_BG[myEl]+';border-radius:12px;padding:12px;margin-bottom:14px;border-left:3px solid '+EL_COLOR[myEl]+'">'
    +'<div style="font-size:12px;color:var(--muted);margin-bottom:4px">'+EL_EMOJI[myEl]+' '+myEl+'('+EL_KO[myEl]+') 오행 맞춤 제품</div>'
    +'<div style="font-size:14px;font-weight:800;color:'+EL_COLOR[myEl]+'">오행 에너지에 최적화된 뷰티 큐레이션</div>'
    +'<div style="font-size:11px;color:var(--muted);margin-top:4px">쿠팡 파트너스 연계 · 최저가 바로 구매</div>'
    +'</div>';
  cats.forEach(function(cat){
    html+='<div class="product-cat-title">'+cat+'</div>';
    catMap[cat].forEach(function(p){
      html+='<div class="product-card">'
        +'<div class="product-info"><div class="p-cat">'+p.cat+'</div>'
        +'<div class="p-name">'+p.name+'</div>'
        +'<div class="p-why">'+p.why+'</div></div>'
        +'<button class="btn-buy" onclick="goCoupang(\''+p.kw.replace(/'/g,'\\\'')+'\')">'
        +'<i class="fa-solid fa-cart-shopping" style="margin-right:4px"></i>구매</button>'
        +'</div>';
    });
  });
  document.getElementById('s6-blur').innerHTML=html;
}

function goCoupang(kw){
  window.open('https://www.coupang.com/np/search?q='+encodeURIComponent(kw)+'&channel=user','_blank');
}

// Pricing
function renderPricing(){
  var el=state.vCore?state.vCore.dayEl:'木';
  document.getElementById('pricing-killing').textContent=
    EL_EMOJI[el]+' 당신의 '+el+'('+EL_KO[el]+') 오행이 추천하는 뷰티 루틴 →';
  selectPlan('full');
}

// ── PLAN SELECT ──────────────────────────────────────
var curPlan='full',curPlanM='ai';
function selectPlan(k){
  curPlan=k;
  ['full','ai','unlimited'].forEach(function(pk){
    var c=document.getElementById('plan-'+pk);
    var r=document.getElementById('radio-'+pk);
    if(c) c.classList.toggle('selected',pk===k);
    if(r) r.classList.toggle('checked',pk===k);
  });
  var btn=document.getElementById('btn-pay');
  if(btn) btn.textContent=PLANS[k].name+' ₩'+PLANS[k].price.toLocaleString()+' 결제하기';
}
function selectPlanM(k){
  curPlanM=k;
  ['full','ai','unlimited'].forEach(function(pk){
    var c=document.getElementById('m-plan-'+pk);
    var r=document.getElementById('m-radio-'+pk);
    if(c) c.classList.toggle('selected',pk===k);
    if(r) r.classList.toggle('checked',pk===k);
  });
}

// ── PAYMENT ─────────────────────────────────────────
function doPayment(){
  var email=document.getElementById('pay-email').value.trim();
  triggerToss(curPlan,email);
}
function doPaymentModal(){
  var email=document.getElementById('m-pay-email').value.trim();
  closePayModal();
  triggerToss(curPlanM,email);
}

async function triggerToss(planKey,email){
  var plan=PLANS[planKey];
  if(!plan){showToast('플랜을 선택해주세요');return;}
  if(!email){showToast('이메일을 입력해주세요');return;}
  try{
    var toss=TossPayments(TOSS_CLIENT_KEY);
    var orderId='NKAI-'+Date.now();
    if(plan.type==='subscription'){
      await toss.requestBillingAuth('카드',{
        customerKey:email.replace(/[^a-zA-Z0-9]/g,'_'),
        successUrl:location.origin+location.pathname+'?payment=success&plan='+planKey,
        failUrl:location.origin+location.pathname+'?payment=fail'
      });
    } else {
      await toss.requestPayment('카드',{
        amount:plan.price,
        orderId:orderId,
        orderName:'KAI-ZEN '+plan.name,
        customerEmail:email,
        successUrl:location.origin+location.pathname+'?payment=success&plan='+planKey+'&orderId='+orderId,
        failUrl:location.origin+location.pathname+'?payment=fail'
      });
    }
  } catch(e){
    if(e.code&&e.code!=='USER_CANCEL') showToast('결제 오류: '+(e.message||e.code));
  }
}

function checkPaymentResult(){
  var params=new URLSearchParams(location.search);
  if(params.get('payment')==='success'){
    state.userPlan=params.get('plan')||'full';
    unlockPaidSections();
    showToast('결제 완료! 프리미엄 콘텐츠가 잠금 해제되었습니다 🎉');
    history.replaceState({},'',location.pathname);
  }
}

function unlockPaidSections(){
  ['s3-gate','s4-gate','s5-gate','s6-gate'].forEach(function(id){
    var gate=document.getElementById(id);
    if(!gate) return;
    var ov=gate.querySelector('.gate-overlay');
    var bl=gate.querySelector('.blur-content');
    if(ov) ov.style.display='none';
    if(bl){bl.style.filter='none';bl.style.pointerEvents='auto';bl.style.userSelect='auto';}
  });
}

// ── MODAL ────────────────────────────────────────────
function openPayModal(planKey){
  selectPlanM(planKey||'ai');
  document.getElementById('pay-modal').classList.add('show');
}
function closePayModal(e){
  if(e&&e.target!==document.getElementById('pay-modal')) return;
  document.getElementById('pay-modal').classList.remove('show');
}

// ── THEME / TOAST ────────────────────────────────────
function toggleTheme(){
  var t=document.documentElement.getAttribute('data-theme');
  document.documentElement.setAttribute('data-theme',t==='dark'?'light':'dark');
}
function showToast(msg){
  var t=document.getElementById('toast');
  t.textContent=msg; t.style.display='block';
  setTimeout(function(){t.style.display='none';},3000);
}

// ── INIT ─────────────────────────────────────────────
checkPaymentResult();
</script>
</body>
</html>
