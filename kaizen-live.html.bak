<!DOCTYPE html>
<html lang="ko" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>KAI-ZEN — 오행 뷰티 & 웰니스</title>
<script src="https://js.tosspayments.com/v2/standard"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<style>
:root{
  --bg:#09090f;--card:#12121e;--card2:#1a1a2e;
  --border:rgba(255,255,255,0.08);--text:#e8e8f0;--muted:#8888aa;
  --accent:#7C5BF0;--accent2:#00D68F;--danger:#ef4444;
  --wood:#22c55e;--fire:#ef4444;--earth:#f59e0b;--metal:#94a3b8;--water:#3b82f6;
  --grad:linear-gradient(135deg,#7C5BF0,#00D68F);
}
[data-theme="light"]{--bg:#f0f0f8;--card:#fff;--card2:#f8f8ff;--border:rgba(0,0,0,0.1);--text:#1a1a2e;--muted:#6b7280;}
*{box-sizing:border-box;margin:0;padding:0}
html,body{font-family:'Apple SD Gothic Neo','Noto Sans KR',sans-serif;background:var(--bg);color:var(--text)}
a{color:inherit;text-decoration:none}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--accent);border-radius:2px}
#app{max-width:480px;margin:0 auto;min-height:100vh}

/* HEADER */
.kz-header{padding:14px 20px 12px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);background:rgba(9,9,15,0.96);backdrop-filter:blur(20px);position:sticky;top:0;z-index:100}
[data-theme="light"] .kz-header{background:rgba(240,240,248,0.96)}
.kz-logo{font-size:20px;font-weight:900;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.kz-logo span{font-size:10px;display:block;font-weight:400;color:var(--muted);-webkit-text-fill-color:var(--muted);letter-spacing:1px}
.kz-header-right{display:flex;gap:8px;align-items:center}
.btn-sm{padding:6px 12px;border-radius:20px;border:1px solid var(--border);background:transparent;color:var(--text);font-size:12px;cursor:pointer;transition:.2s}
.btn-sm:hover{border-color:var(--accent);color:var(--accent)}
.btn-premium{background:var(--grad);border:none;color:#fff;font-weight:700}
.btn-premium:hover{opacity:.9;color:#fff}

/* INPUT */
.input-section{padding:28px 20px 24px;background:linear-gradient(180deg,rgba(124,91,240,0.1) 0%,transparent 100%)}
.input-title{font-size:22px;font-weight:900;margin-bottom:4px;line-height:1.3}
.input-sub{font-size:13px;color:var(--muted);margin-bottom:20px}
.input-row{display:flex;gap:10px;margin-bottom:12px}
.input-group{flex:1;display:flex;flex-direction:column;gap:6px}
.input-group label{font-size:11px;color:var(--muted);font-weight:600;letter-spacing:.5px;text-transform:uppercase}
.kz-input{width:100%;padding:12px 14px;background:var(--card);border:1px solid var(--border);border-radius:12px;color:var(--text);font-size:14px;outline:none;transition:.2s;-webkit-appearance:none}
.kz-input:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(124,91,240,0.15)}
.kz-input[type=date]::-webkit-calendar-picker-indicator{filter:invert(0.7)}
select.kz-input option{background:var(--card2)}
.btn-analyze{width:100%;padding:16px;border-radius:14px;border:none;background:var(--grad);color:#fff;font-size:16px;font-weight:800;cursor:pointer;transition:.2s;margin-top:8px;letter-spacing:-.3px}
.btn-analyze:hover{opacity:.9;transform:translateY(-1px)}
.btn-analyze:active{transform:translateY(0)}

/* STORY FLOW */
#story-flow{display:none;padding-bottom:40px}
#story-flow.show{display:block}
.section-wrap{padding:0 16px;margin-bottom:6px}
.section-label{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;letter-spacing:.6px;padding:4px 10px;border-radius:20px;margin-bottom:8px}
.label-free{background:rgba(0,214,143,0.15);color:var(--accent2)}
.label-paid{background:rgba(124,91,240,0.15);color:var(--accent)}
.s-card{background:var(--card);border:1px solid var(--border);border-radius:18px;overflow:hidden;margin-bottom:10px}
.s-card-header{padding:16px 18px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px}
.s-num{width:28px;height:28px;border-radius:8px;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:#fff;flex-shrink:0}
.s-title{font-size:16px;font-weight:800}
.s-sub{font-size:12px;color:var(--muted);margin-top:2px}
.s-body{padding:16px 18px}

/* SAJU GRID */
.saju-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px}
.saju-pillar{background:var(--card2);border-radius:12px;padding:10px 6px;text-align:center;border:1px solid var(--border)}
.saju-pillar .pl{font-size:10px;color:var(--muted);margin-bottom:6px;display:block}
.saju-pillar .pg{font-size:22px;font-weight:900;line-height:1;margin-bottom:4px}
.saju-pillar .pz{font-size:18px}

/* OHAENG BARS */
.oh-row{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.oh-lbl{width:24px;font-size:13px;font-weight:700;text-align:center}
.oh-bg{flex:1;height:8px;background:rgba(255,255,255,0.06);border-radius:4px;overflow:hidden}
.oh-fill{height:100%;border-radius:4px;width:0;transition:width 1s cubic-bezier(.4,0,.2,1)}
.oh-val{font-size:12px;color:var(--muted);width:36px;text-align:right}
.dna-banner{padding:14px 16px;background:var(--card2);border-radius:12px;margin-top:4px;border-left:3px solid var(--accent2)}

/* ELEMENT BLOCKS */
.el-block{border-radius:14px;padding:14px;margin-bottom:10px;border:1px solid var(--border)}
.el-block.me{border-width:2px}
.el-header{display:flex;align-items:center;gap:8px;font-size:15px;font-weight:800;margin-bottom:8px;flex-wrap:wrap}
.me-badge{font-size:10px;background:var(--accent);color:#fff;padding:2px 8px;border-radius:10px;margin-left:auto}
.el-trait{font-size:13px;line-height:1.7;color:var(--text);margin-bottom:8px}
.organ-wrap{display:flex;flex-direction:column;gap:6px}
.organ-line{font-size:12px;color:var(--muted);line-height:1.5}
.stress-line{font-size:12px;padding:6px 10px;border-radius:8px;border:1px solid var(--danger);color:var(--danger);background:rgba(239,68,68,0.05)}

/* SKIN FREE BANNER */
.skin-free{background:linear-gradient(135deg,rgba(124,91,240,0.15),rgba(0,214,143,0.1));border-radius:14px;padding:16px;margin-bottom:14px;border:1px solid rgba(124,91,240,0.3)}
.skin-free-title{font-size:15px;font-weight:800;margin-bottom:6px}
.skin-free-desc{font-size:13px;color:var(--muted);line-height:1.6}

/* BLUR GATE */
.pay-gate{position:relative;margin-bottom:4px}
.blur-content{filter:blur(4px);pointer-events:none;user-select:none}
.gate-overlay{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(180deg,transparent 0%,rgba(9,9,15,0.85) 35%,rgba(9,9,15,0.96) 100%);border-radius:18px;padding:24px;text-align:center;gap:10px}
[data-theme="light"] .gate-overlay{background:linear-gradient(180deg,transparent 0%,rgba(240,240,248,0.85) 35%,rgba(240,240,248,0.96) 100%)}
.gate-icon{font-size:36px;color:var(--accent);margin-bottom:4px}
.gate-title{font-size:15px;font-weight:800}
.gate-price{font-size:13px;color:var(--muted)}
.btn-unlock{padding:12px 28px;border-radius:12px;border:none;background:var(--grad);color:#fff;font-size:14px;font-weight:800;cursor:pointer;transition:.2s}
.btn-unlock:hover{opacity:.9}

/* WELLNESS TAGS */
.wtag{display:inline-block;padding:3px 9px;border-radius:6px;font-size:11px;font-weight:600;margin:2px}
.wtag-g{background:rgba(0,214,143,0.12);color:var(--accent2)}
.wtag-b{background:rgba(239,68,68,0.12);color:#f87171}
.wtag-r{background:rgba(124,91,240,0.12);color:var(--accent)}
.w-lbl{font-size:11px;color:var(--muted);font-weight:600;letter-spacing:.4px;margin:10px 0 4px;display:block}

/* DIET / EXERCISE BLOCKS */
.item-block{background:var(--card2);border-radius:12px;padding:14px;margin-bottom:10px;border:1px solid var(--border)}
.item-block.me{border-width:2px}
.item-header{display:flex;align-items:center;gap:8px;font-size:14px;font-weight:700;margin-bottom:10px;flex-wrap:wrap}

/* PRODUCT CARDS */
.product-cat-title{font-size:12px;font-weight:700;color:var(--muted);letter-spacing:.5px;margin:12px 0 6px;text-transform:uppercase}
.product-card{display:flex;align-items:center;justify-content:space-between;background:var(--card2);border:1px solid var(--border);border-radius:12px;padding:12px 14px;margin-bottom:8px}
.product-info .p-cat{font-size:10px;color:var(--muted);margin-bottom:2px}
.product-info .p-name{font-size:13px;font-weight:700;line-height:1.4}
.product-info .p-why{font-size:11px;color:var(--muted);margin-top:2px}
.btn-buy{padding:7px 14px;border-radius:8px;border:none;background:rgba(124,91,240,0.2);color:var(--accent);font-size:12px;font-weight:700;cursor:pointer;flex-shrink:0;margin-left:10px;transition:.2s;white-space:nowrap}
.btn-buy:hover{background:var(--accent);color:#fff}

/* PRICING */
.pricing-wrap{padding:24px 16px 20px}
.pricing-title{font-size:20px;font-weight:900;text-align:center;margin-bottom:6px;line-height:1.3}
.pricing-killing{font-size:14px;color:var(--accent2);text-align:center;margin-bottom:22px;font-weight:600}
.plan-grid{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.plan-card{background:var(--card);border:1.5px solid var(--border);border-radius:14px;padding:14px 16px;cursor:pointer;transition:.2s;display:flex;align-items:center;gap:12px}
.plan-card:hover{border-color:var(--accent)}
.plan-card.selected{border-color:var(--accent);background:rgba(124,91,240,0.1)}
.plan-card.recommended{border-color:var(--accent2)}
.plan-icon{font-size:28px;flex-shrink:0}
.plan-name{font-size:15px;font-weight:700}
.plan-badge{font-size:9px;background:var(--accent2);color:#000;padding:2px 6px;border-radius:4px;font-weight:700;margin-left:6px}
.plan-price{font-size:14px;color:var(--accent);font-weight:700}
.plan-features{font-size:11px;color:var(--muted);margin-top:2px}
.plan-radio{width:20px;height:20px;border-radius:50%;border:2px solid var(--border);flex-shrink:0;margin-left:auto;display:flex;align-items:center;justify-content:center}
.plan-radio.checked::after{content:'';width:10px;height:10px;background:var(--accent);border-radius:50%;display:block}
.btn-pay{width:100%;padding:16px;border-radius:14px;border:none;background:var(--grad);color:#fff;font-size:16px;font-weight:800;cursor:pointer;transition:.2s}
.btn-pay:hover{opacity:.9}

/* FOOTER */
.kz-footer{padding:24px 20px;text-align:center;border-top:1px solid var(--border)}
.kz-footer-logo{font-size:13px;font-weight:700;color:var(--muted);margin-bottom:4px}
.kz-footer-sub{font-size:11px;color:var(--muted);opacity:.6}

/* MODAL */
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:500;align-items:flex-end;justify-content:center}
.modal-bg.show{display:flex}
.modal-sheet{background:var(--card);border-radius:24px 24px 0 0;padding:24px 20px 36px;width:100%;max-width:480px;animation:slideUp .3s ease;max-height:90vh;overflow-y:auto}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:0 auto 20px;cursor:pointer}
.modal-title{font-size:18px;font-weight:800;margin-bottom:6px}
.modal-sub{font-size:13px;color:var(--muted);margin-bottom:20px}

/* TOAST */
#toast{position:fixed;top:70px;left:50%;transform:translateX(-50%);background:rgba(0,214,143,0.15);border:1px solid var(--accent2);color:var(--accent2);padding:10px 20px;border-radius:12px;font-size:13px;font-weight:600;z-index:999;display:none;white-space:nowrap}

/* MISC */
.divider{height:1px;background:var(--border);margin:14px 0}
.loading-dots::after{content:'';animation:dots 1.5s steps(4,end) infinite}
@keyframes dots{0%,20%{content:''}40%{content:'.'}60%{content:'..'}80%,100%{content:'...'}}
</style>
</head>
<body>
<div id="app">

  <!-- HEADER -->
  <header class="kz-header">
    <div>
      <div class="kz-logo">KAI-ZEN<span>오행 뷰티 & 웰니스 AI</span></div>
    </div>
    <div class="kz-header-right">
      <button class="btn-sm" onclick="toggleTheme()"><i class="fa-solid fa-moon"></i></button>
      <button class="btn-sm btn-premium" onclick="openPayModal(null)"><i class="fa-solid fa-crown" style="margin-right:4px"></i>프리미엄</button>
    </div>
  </header>

  <!-- INPUT -->
  <div class="input-section">
    <div class="input-title">오행이 알려주는<br>나만의 뷰티 루틴</div>
    <div class="input-sub">생년월일 입력 → 나만의 맞춤 분석이 한 페이지로 펼쳐집니다</div>
    <div class="input-row">
      <div class="input-group">
        <label>생년월일</label>
        <input type="date" class="kz-input" id="birth-date" min="1920-01-01" max="2010-12-31" value="1990-01-01">
      </div>
      <div class="input-group" style="max-width:110px">
        <label>성별</label>
        <select class="kz-input" id="birth-gender">
          <option value="M">남성</option>
          <option value="F" selected>여성</option>
        </select>
      </div>
    </div>
    <div class="input-row">
      <div class="input-group">
        <label>출생 시간 <span style="color:var(--accent2);font-size:9px">선택 · 정밀도↑</span></label>
        <select class="kz-input" id="birth-hour">
          <option value="">모름</option>
          <option value="0">子時 (23~01시)</option>
          <option value="1">丑時 (01~03시)</option>
          <option value="2">寅時 (03~05시)</option>
          <option value="3">卯時 (05~07시)</option>
          <option value="4">辰時 (07~09시)</option>
          <option value="5">巳時 (09~11시)</option>
          <option value="6">午時 (11~13시)</option>
          <option value="7">未時 (13~15시)</option>
          <option value="8">申時 (15~17시)</option>
          <option value="9">酉時 (17~19시)</option>
          <option value="10">戌時 (19~21시)</option>
          <option value="11">亥時 (21~23시)</option>
        </select>
      </div>
    </div>
    <button class="btn-analyze" onclick="doAnalyze()">
      <i class="fa-solid fa-wand-magic-sparkles" style="margin-right:8px"></i>사주 분석하기
    </button>
  </div>

  <!-- STORY FLOW -->
  <div id="story-flow">

    <!-- S1: 나의 오행 DNA (무료) -->
    <div class="section-wrap">
      <div class="section-label label-free"><i class="fa-solid fa-dna"></i>&nbsp;무료 분석</div>
      <div class="s-card">
        <div class="s-card-header">
          <div class="s-num">1</div>
          <div><div class="s-title">나의 오행 DNA</div><div class="s-sub">사주 4주 & 오행 에너지 분포</div></div>
        </div>
        <div class="s-body">
          <div class="saju-grid" id="s1-grid"></div>
          <div id="s1-bars"></div>
          <div class="dna-banner" id="s1-banner"></div>
        </div>
      </div>
    </div>

    <!-- S2: 오행별 성격과 체질 (무료) -->
    <div class="section-wrap">
      <div class="section-label label-free"><i class="fa-solid fa-user-check"></i>&nbsp;무료 분석</div>
      <div class="s-card">
        <div class="s-card-header">
          <div class="s-num">2</div>
          <div><div class="s-title">오행별 성격과 체질</div><div class="s-sub">5가지 오행의 기질 · 신체 약점</div></div>
        </div>
        <div class="s-body" id="s2-body"></div>
      </div>
    </div>

    <!-- S3: 이번달 피부/헤어 운세 (일부 무료) -->
    <div class="section-wrap">
      <div class="section-label label-free"><i class="fa-solid fa-face-smile-beam"></i>&nbsp;일부 무료</div>
      <div class="s-card">
        <div class="s-card-header">
          <div class="s-num">3</div>
          <div><div class="s-title">이번 달 피부·헤어 운세</div><div class="s-sub">오행 에너지 기반 월별 케어 가이드</div></div>
        </div>
        <div class="s-body">
          <div class="skin-free" id="s3-free"></div>
          <div class="pay-gate" id="s3-gate">
            <div class="blur-content" id="s3-blur"></div>
            <div class="gate-overlay">
              <div class="gate-icon"><i class="fa-solid fa-lock"></i></div>
              <div class="gate-title">상세 피부·헤어 관리법 잠금 해제</div>
              <div class="gate-price">₩3,900 · 전체 분석 패키지</div>
              <button class="btn-unlock" onclick="openPayModal('full')">지금 열기 →</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- S4: 웰니스 식단 (유료) -->
    <div class="section-wrap">
      <div class="section-label label-paid"><i class="fa-solid fa-crown"></i>&nbsp;프리미엄</div>
      <div class="s-card">
        <div class="s-card-header">
          <div class="s-num">4</div>
          <div><div class="s-title">웰니스 식단</div><div class="s-sub">오행별 추천·금지 식품 & 레시피</div></div>
        </div>
        <div class="s-body">
          <div class="pay-gate" id="s4-gate">
            <div class="blur-content" id="s4-blur"></div>
            <div class="gate-overlay">
              <div class="gate-icon"><i class="fa-solid fa-lock"></i></div>
              <div class="gate-title">맞춤 식단 가이드 잠금 해제</div>
              <div class="gate-price">₩3,900 · 전체 분석 패키지</div>
              <button class="btn-unlock" onclick="openPayModal('full')">지금 열기 →</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- S5: 추천 운동 (유료) -->
    <div class="section-wrap">
      <div class="section-label label-paid"><i class="fa-solid fa-crown"></i>&nbsp;프리미엄</div>
      <div class="s-card">
        <div class="s-card-header">
          <div class="s-num">5</div>
          <div><div class="s-title">추천 운동</div><div class="s-sub">오행별 신체 강화 운동 루틴</div></div>
        </div>
        <div class="s-body">
          <div class="pay-gate" id="s5-gate">
            <div class="blur-content" id="s5-blur"></div>
            <div class="gate-overlay">
              <div class="gate-icon"><i class="fa-solid fa-lock"></i></div>
              <div class="gate-title">맞춤 운동 루틴 잠금 해제</div>
              <div class="gate-price">₩3,900 · 전체 분석 패키지</div>
              <button class="btn-unlock" onclick="openPayModal('full')">지금 열기 →</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- S6: 맞춤 뷰티 제품 (유료) -->
    <div class="section-wrap">
      <div class="section-label label-paid"><i class="fa-solid fa-bag-shopping"></i>&nbsp;프리미엄 · 수익 핵심</div>
      <div class="s-card">
        <div class="s-card-header">
          <div class="s-num">6</div>
          <div><div class="s-title">맞춤 뷰티 제품 추천</div><div class="s-sub">오행 에너지 최적화 제품 큐레이션 + 구매링크</div></div>
        </div>
        <div class="s-body">
          <div class="pay-gate" id="s6-gate">
            <div class="blur-content" id="s6-blur"></div>
            <div class="gate-overlay">
              <div class="gate-icon"><i class="fa-solid fa-bag-shopping"></i></div>
              <div class="gate-title">오행 맞춤 뷰티 제품 추천 열기</div>
              <div class="gate-price">₩3,900 · 구매하기 버튼 포함</div>
